APP_NAME=Triplet
APP_ENV=staging
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/triplet_staging
FRONTEND_URL=https://staging.triplet.example
API_PUBLIC_BASE_URL=https://api-staging.triplet.example
AUTH_PUBLIC_BASE_URL=https://api-staging.triplet.example

FLIGHT_PROVIDER=hybrid
ENABLE_DEV_TOOL_ENDPOINTS=false
SKYSCANNER_API_ENABLED=false
SKYSCANNER_API_KEY=
SKYSCANNER_BASE_URL=https://partners.api.skyscanner.net
SKYSCANNER_TIMEOUT_SECONDS=20
SKYSCANNER_MAX_REQUESTS_PER_SEARCH=30
SKYSCANNER_CACHE_ENABLED=true
SKYSCANNER_MARKET=SI
SKYSCANNER_LOCALE=en-GB
SKYSCANNER_CURRENCY=EUR
SKYSCANNER_USE_INDICATIVE_PRICES=true
SKYSCANNER_USE_LIVE_PRICES=true
SKYSCANNER_POLL_ATTEMPTS=3
SKYSCANNER_POLL_DELAY_SECONDS=1
SKYSCANNER_AFFILIATE_ENABLED=true
SKYSCANNER_MEDIA_PARTNER_ID=
SKYSCANNER_AFFILIATE_BASE_URL=https://skyscanner.net/g/referrals/v1
SKYSCANNER_AFFILIATE_UTM_SOURCE=triplet
SKYSCANNER_AFFILIATE_UTM_MEDIUM=affiliate
SKYSCANNER_AFFILIATE_UTM_CAMPAIGN=triplet_search

AI_ENABLED=false
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TEMPERATURE=0.2
OPENAI_REASONING_EFFORT=low
AI_MAX_TOOL_CALLS=3
AI_REQUIRE_TOOL_RESULTS=true
AI_MAX_TRIPS_SENT_TO_MODEL=8

APP_SECRET=replace-with-a-long-random-secret
AUTH_ENABLED=true
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=none
AUTH_COOKIE_DOMAIN=
AUTH_PASSWORD_MIN_LENGTH=12
AUTH_RATE_LIMIT_WINDOW_SECONDS=300
AUTH_RATE_LIMIT_MAX_ATTEMPTS=20
API_RATE_LIMIT_WINDOW_SECONDS=60
TRIPS_SEARCH_RATE_LIMIT_MAX_ATTEMPTS=60
AI_SEARCH_RATE_LIMIT_MAX_ATTEMPTS=20
PROVIDER_SMOKE_TEST_RATE_LIMIT_MAX_ATTEMPTS=10

BILLING_ENABLED=false
EMAIL_PROVIDER=console
EMAIL_FROM=alerts@triplet.example
